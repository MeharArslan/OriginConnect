<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oc_bg"
    android:paddingHorizontal="32dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/imgLogo"
            android:layout_width="80dp" android:layout_height="80dp"
            android:src="@drawable/ic_oc_logo"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/welcome_title" android:textSize="30sp"
            android:textStyle="bold" android:textColor="@color/oc_text_primary"
            android:fontFamily="sans-serif-medium" android:layout_marginTop="32dp"
            android:gravity="center" android:lineSpacingMultiplier="1.2"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/welcome_desc" android:textSize="15sp"
            android:textColor="@color/oc_text_secondary" android:layout_marginTop="16dp"
            android:gravity="center" android:lineSpacingMultiplier="1.4"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="40dp"
            android:gravity="center">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_lock" android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="End-to-end encrypted" android:textSize="13sp"
                android:textColor="@color/oc_text_secondary"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:paddingBottom="48dp">
        <Button android:id="@+id/btnAgree"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/agree_continue"
            android:background="@drawable/bg_btn_primary"
            android:textColor="@color/oc_text_primary"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/terms_privacy"
            android:textSize="12sp" android:textColor="@color/oc_text_secondary"
            android:gravity="center" android:layout_marginTop="16dp"
            android:lineSpacingMultiplier="1.5"/>
    </LinearLayout>
</LinearLayout>